# OS
.DS_Store

# Live registries are private-mirror-only (lyrikai-os/lk-bloom).
# Public tip must never include them — publish via scripts/publish-public-tip.sh
# which excludes registry/private/**. Parent may track that folder; do not
# sync it to lk-bloom/hive.
# (Intentionally not gitignored on the private parent so Admin can version it.)

# Secrets (never commit)
**/.env*
!**/.env.example
**/*.pem
**/secrets/
**/credentials.json

# Dependencies & build
**/node_modules/
**/.next/
**/out/
**/build/
**/dist/
**/.astro/

# Logs / coverage
**/coverage/
**/*.tsbuildinfo
**/npm-debug.log*
